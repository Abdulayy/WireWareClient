<Page
    x:Class="WireWareClient.NewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.Resources>
            <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron</FontFamily>
        </Grid.Resources>

        <StackPanel Spacing="30" Margin="20,20,40,20">
            <TextBlock Text="KERNEL UPDATE FEED" FontFamily="{StaticResource OrbitronFont}" FontSize="32" FontWeight="Black" Foreground="White"/>

            <ListView x:Name="NewsList" SelectionMode="None" Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1B1B1B" Margin="0,0,0,15" Padding="25" CornerRadius="16" BorderBrush="#2C2C2C" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <TextBlock Text="{Binding Title}" FontFamily="{StaticResource OrbitronFont}" FontSize="18" FontWeight="Bold" Foreground="#BA7543"/>
                                    <TextBlock Text="{Binding Date}" FontFamily="{StaticResource OrbitronFont}" FontSize="12" HorizontalAlignment="Right" Foreground="#888888"/>
                                </Grid>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="14" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
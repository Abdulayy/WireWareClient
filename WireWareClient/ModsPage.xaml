<Page
    x:Class="WireWareClient.ModsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.Resources>
            <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron</FontFamily>
        </Grid.Resources>

        <StackPanel Spacing="30" Margin="20,20,40,20">
            <TextBlock Text="MODULAR REPOSITORY" FontFamily="{StaticResource OrbitronFont}" FontSize="32" FontWeight="Black" Foreground="White"/>

            <Grid ColumnDefinitions="*, Auto" MaxWidth="800" HorizontalAlignment="Left">
                <TextBox x:Name="ModSearchInput" PlaceholderText="SEARCH KERNEL MODULES (SODIUM, CREATE...)" 
                         FontFamily="{StaticResource OrbitronFont}" FontSize="14" Height="50" 
                         Background="#1B1B1B" BorderBrush="#2C2C2C" CornerRadius="12">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#BA7543"/>
                    </TextBox.Resources>
                </TextBox>
                <Button Grid.Column="1" Content="SEARCH" FontFamily="{StaticResource OrbitronFont}" 
                        Margin="15,0,0,0" Height="50" Width="120" Background="#BA7543" 
                        Foreground="White" CornerRadius="12" Click="Search_Click"/>
            </Grid>

            <GridView x:Name="ModsGallery" SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1B1B1B" Width="220" Height="280" CornerRadius="20" BorderBrush="#2C2C2C" BorderThickness="1" Margin="10">
                            <StackPanel Padding="15" Spacing="10">
                                <Border Height="120" CornerRadius="12" Background="#121212">
                                    <SymbolIcon Symbol="Library" Foreground="#BA7543" RenderTransformOrigin="0.5,0.5">
                                        <SymbolIcon.RenderTransform>
                                            <ScaleTransform ScaleX="2.5" ScaleY="2.5"/>
                                        </SymbolIcon.RenderTransform>
                                    </SymbolIcon>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontFamily="{StaticResource OrbitronFont}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding Author}" FontSize="11" Foreground="#BA7543" Opacity="0.8"/>
                                <Button Content="DOWNLOAD" Background="#2C2C2C" HorizontalAlignment="Stretch" CornerRadius="8" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </Grid>
</Page>
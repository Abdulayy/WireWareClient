<Page
    x:Class="WireWareClient.MenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.Resources>
            <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron</FontFamily>
        </Grid.Resources>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="0,15,40,0" Canvas.ZIndex="10" Spacing="15">
            <TextBlock x:Name="UserAliasText" Text="ENTITY_0" FontFamily="{StaticResource OrbitronFont}" FontSize="18" Foreground="White" VerticalAlignment="Center" Opacity="0.9"/>
            <Border Width="50" Height="50" CornerRadius="25" BorderBrush="#BA7543" BorderThickness="2">
                <Border.Background>
                    <ImageBrush x:Name="HeaderProfilePic" ImageSource="ms-appx:///Assets/Logos/ProfilePic.jpg" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
        </StackPanel>

        <NavigationView x:Name="MainNav" 
                PaneDisplayMode="Left" 
                Background="Transparent" 
                IsBackButtonVisible="Collapsed" 
                Header="DASHBOARD INTERFACE" 
                SelectionChanged="MainNav_SelectionChanged">
            <!-- ? Changed from ItemInvoked -->

            <NavigationView.MenuItems>
                <NavigationViewItem Content="INSTANCES" Icon="Home" Tag="dash" FontFamily="{StaticResource OrbitronFont}"/>
                <NavigationViewItem Content="KERNEL NEWS" Icon="World" Tag="news" FontFamily="{StaticResource OrbitronFont}"/>
                <NavigationViewItem Content="MOD MODULES" Icon="Library" Tag="mods" FontFamily="{StaticResource OrbitronFont}"/>
                <NavigationViewItem Content="ACCOUNT" Icon="Contact" Tag="account" FontFamily="{StaticResource OrbitronFont}"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="SETTINGS" Icon="Setting" Tag="settings" FontFamily="{StaticResource OrbitronFont}"/>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Margin="20,0,20,20">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="30"/>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
<Window
    x:Class="WireWareClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WireWareClient">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron</FontFamily>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="28,0,0,0">
                <TextBlock Text="WIREWARE" FontFamily="{StaticResource OrbitronFont}" FontSize="14" FontWeight="Black" Foreground="#BA7543" CharacterSpacing="180"/>
                <TextBlock Text="KERNEL" FontFamily="{StaticResource OrbitronFont}" FontSize="14" Foreground="White" Margin="12,0,0,0" Opacity="0.4"/>
            </StackPanel>
        </Grid>
        <Frame x:Name="RootFrame" Grid.Row="1" Background="Transparent" />
    </Grid>
</Window>
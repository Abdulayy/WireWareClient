<Page
    x:Class="WireWareClient.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Border Background="#121212" 
                Width="550" 
                Padding="60" 
                CornerRadius="36" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                BorderBrush="#2C2C2C"
                BorderThickness="1">

            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <StackPanel Spacing="45">
                <StackPanel Spacing="12">
                    <TextBlock Text="KERNEL IDENTITY" 
                               FontFamily="ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron"
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               HorizontalAlignment="Center"
                               CharacterSpacing="50"/>
                    <TextBlock Text="ESTABLISH LOCAL ALIAS FOR OFFLINE BYPASS" 
                               FontFamily="ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron"
                               FontSize="10" 
                               Foreground="#BA7543" 
                               HorizontalAlignment="Center"
                               Opacity="0.8"/>
                </StackPanel>

                <TextBox x:Name="UsernameInput" 
                         PlaceholderText="ALIAS..." 
                         FontSize="20"
                         FontFamily="ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron"
                         HorizontalAlignment="Stretch"
                         TextAlignment="Center"
                         BorderThickness="1"
                         CornerRadius="14"
                         Height="60"
                         Background="#1B1B1B">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#BA7543"/>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1B1B1B"/>
                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="White"/>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="LoginButton"
                        Content="INITIALIZE ACCESS" 
                        FontFamily="ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron"
                        HorizontalAlignment="Stretch"
                        Height="60"
                        Background="#BA7543" 
                        Foreground="White" 
                        FontSize="18"
                        FontWeight="Bold"
                        CornerRadius="14"
                        Click="LoginButton_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#D48B5A"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#8C5632"/>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
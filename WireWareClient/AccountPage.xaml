<Page
    x:Class="WireWareClient.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.Resources>
            <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron</FontFamily>
        </Grid.Resources>

        <ScrollViewer MaxWidth="900" HorizontalAlignment="Left">
            <StackPanel Spacing="35" Margin="20,20,0,0">
                <TextBlock Text="IDENTITY MANAGEMENT" 
                           FontFamily="{StaticResource OrbitronFont}" 
                           FontSize="32" 
                           FontWeight="Black" 
                           Foreground="White"/>

                <!-- Avatar Section -->
                <Border Background="#1B1B1B" 
                        Padding="30" 
                        CornerRadius="20" 
                        BorderBrush="#2C2C2C" 
                        BorderThickness="1">
                    <Grid ColumnDefinitions="Auto, *">
                        <Ellipse Width="120" Height="120" Stroke="#BA7543" StrokeThickness="2">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="LocalAvatarPreview" 
                                            ImageSource="ms-appx:///Assets/Logos/ProfilePic.jpg" 
                                            Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <StackPanel Grid.Column="1" Margin="30,0,0,0" 
                                    VerticalAlignment="Center" Spacing="15">
                            <TextBlock Text="KERNEL AVATAR" 
                                       FontFamily="{StaticResource OrbitronFont}" 
                                       FontSize="18" 
                                       Foreground="White"/>
                            <TextBlock Text="Update your local identity visual within the distribution frame." 
                                       FontSize="12" 
                                       Foreground="#888888"/>
                            <Button Content="BROWSE IMAGE" 
                                    Background="#BA7543" 
                                    Width="180" 
                                    Height="40" 
                                    CornerRadius="8" 
                                    Click="PickAvatar_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Skin Section with fixed warning -->
                <Border Background="#1B1B1B" 
                        Padding="30" 
                        CornerRadius="20" 
                        BorderBrush="#2C2C2C" 
                        BorderThickness="1">
                    <StackPanel Spacing="20">
                        <TextBlock Text="MINECRAFT SKIN (OFFLINE)" 
                                   FontFamily="{StaticResource OrbitronFont}" 
                                   FontSize="18" 
                                   Foreground="White"/>

                        <!-- WARNING: Using inner text + xml:space="preserve" for safe line breaks -->
                        <TextBlock FontSize="12" 
                                   Foreground="#FF6347" 
                                   TextWrapping="Wrap" 
                                   LineHeight="18" 
                                   xml:space="preserve">
Custom offline skins work ONLY in Minecraft 1.19.2 and lower (pure vanilla, no mods).

In 1.19.3 and newer versions (1.20+, 1.21+, etc.) vanilla Minecraft does NOT support local custom skins without the OfflineSkins mod or an online Microsoft account.

You will get one of the default skins (Steve, Alex, Sunny, Efe, etc.) assigned by UUID.
                        </TextBlock>

                        <Grid ColumnDefinitions="*, Auto" Margin="0,12,0,0">
                            <TextBlock Text="Assign a .png texture to your alias for local sessions (legacy support only)." 
                                       FontSize="12" 
                                       Foreground="#888888" 
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" 
                                    Content="SELECT SKIN" 
                                    Background="#121212" 
                                    BorderBrush="#BA7543" 
                                    BorderThickness="1" 
                                    Width="180" 
                                    Height="45" 
                                    CornerRadius="8" 
                                    Click="PickSkin_Click"/>
                        </Grid>

                        <Border Height="2" Background="#2C2C2C" Margin="0,8,0,8"/>

                        <TextBlock x:Name="SkinPathText" 
                                   Text="No custom skin linked." 
                                   FontSize="11" 
                                   Foreground="#BA7543" 
                                   Opacity="0.7"/>

                        <TextBlock x:Name="SkinStatus" 
                                   Text="" 
                                   FontSize="11" 
                                   Foreground="#BA7543" 
                                   Opacity="0.9"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
<Page
    x:Class="WireWareClient.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.Resources>
            <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Medium.ttf#Orbitron</FontFamily>
        </Grid.Resources>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- Instances + RADMIN -->
                <RowDefinition Height="Auto"/>
                <!-- Bottom controls -->
            </Grid.RowDefinitions>

            <!-- Instances gallery (left side) -->
            <GridView x:Name="InstanceGallery" 
          Width="850" 
          Height="380" 
          SelectionMode="None">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                           MaximumRowsOrColumns="2"
                           ItemWidth="200"
                           ItemHeight="260" />
                        <!-- Slightly taller for extra button -->
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1B1B1B" 
                    Width="180" 
                    Height="240" 
                    CornerRadius="16" 
                    BorderBrush="#2C2C2C" 
                    BorderThickness="1" 
                    Margin="10">
                            <StackPanel VerticalAlignment="Center" Spacing="12">
                                <SymbolIcon Symbol="Target" Foreground="#BA7543">
                                    <SymbolIcon.RenderTransform>
                                        <ScaleTransform ScaleX="2" ScaleY="2"/>
                                    </SymbolIcon.RenderTransform>
                                </SymbolIcon>
                                <TextBlock Text="{Binding}" 
                               FontFamily="{StaticResource OrbitronFont}" 
                               HorizontalAlignment="Center" 
                               FontSize="14" 
                               TextWrapping="Wrap" 
                               TextAlignment="Center"/>
                                <Button Content="BOOT" 
                            Background="#BA7543" 
                            Width="120" 
                            Height="36" 
                            CornerRadius="8" 
                            HorizontalAlignment="Center" 
                            Click="Play_Click" 
                            Tag="{Binding}"/>
                                <!-- New enForge button -->
                                <Button Content="enForge" 
                            Background="#1B1B1B" 
                            BorderBrush="#BA7543" 
                            BorderThickness="1" 
                            Foreground="#BA7543" 
                            Width="120" 
                            Height="32" 
                            CornerRadius="8" 
                            HorizontalAlignment="Center" 
                            FontSize="12" 
                            Click="EnForge_Click" 
                            Tag="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- RADMIN panel — unchanged -->
            <Border Grid.Column="1" Grid.Row="0"
                    Background="#1B1B1B" CornerRadius="20" BorderBrush="#BA7543" BorderThickness="2"
                    Margin="30,0,0,0" Padding="16" Width="280" VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <TextBlock Text="RADMIN" FontFamily="{StaticResource OrbitronFont}" FontSize="28" 
                               Foreground="#BA7543" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <StackPanel Spacing="10">
                        <TextBlock Text="PUBLIC IP" Foreground="#BA7543" Opacity="0.7" FontFamily="{StaticResource OrbitronFont}" FontSize="11"/>
                        <TextBlock x:Name="IpText" Text="LOADING..." Foreground="White" FontFamily="{StaticResource OrbitronFont}" FontSize="13" TextWrapping="Wrap"/>

                        <TextBlock Text="LOCATION" Foreground="#BA7543" Opacity="0.7" FontFamily="{StaticResource OrbitronFont}" FontSize="11" Margin="0,10,0,0"/>
                        <TextBlock x:Name="LocationText" Text="LOADING..." Foreground="White" FontFamily="{StaticResource OrbitronFont}" FontSize="13" TextWrapping="Wrap"/>

                        <TextBlock Text="ISP" Foreground="#BA7543" Opacity="0.7" FontFamily="{StaticResource OrbitronFont}" FontSize="11" Margin="0,10,0,0"/>
                        <TextBlock x:Name="IspText" Text="LOADING..." Foreground="White" FontFamily="{StaticResource OrbitronFont}" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            


            <!-- Bottom controls — unchanged -->
            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Spacing="20" Margin="0,30,0,0">
                <TextBlock x:Name="StatusLabel" Text="IDLE" FontFamily="{StaticResource OrbitronFont}" FontSize="12" Foreground="#BA7543"/>
                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Left">
                    <Button x:Name="VersionBtn" Background="#1B1B1B" BorderBrush="#BA7543" BorderThickness="1" CornerRadius="12" Width="300" Height="65">
                        <Button.Content>
                            <Grid ColumnDefinitions="*, Auto" Width="260">
                                <TextBlock x:Name="SelectedVersionText" Text="SELECT VERSION" FontFamily="{StaticResource OrbitronFont}" FontSize="16" VerticalAlignment="Center"/>
                                <FontIcon Glyph="?" Grid.Column="1" FontSize="14" Foreground="#BA7543"/>
                            </Grid>
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout x:Name="VersionListFlyout" Placement="Top"/>
                        </Button.Flyout>
                    </Button>
                    <Button x:Name="InstallBtn" Content="INSTALL INSTANCE" Width="300" Height="65" 
                            Background="#BA7543" Foreground="White" FontWeight="Bold" CornerRadius="12"
                            FontSize="18" FontFamily="{StaticResource OrbitronFont}" Click="Install_Click"/>
                </StackPanel>
                <ProgressBar x:Name="DownloadProgress" Width="620" Height="4" Background="#1B1B1B" Foreground="#BA7543" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>